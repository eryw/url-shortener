# Base URL for short links (required)
# Example: https://go.example.com
BASE_URL=https://go.yourdomain.com

# Server port (default: 8080)
PORT=8080

# SQLite database path (default: ./data/urls.db)
DB_PATH=./data/urls.db

# Session secret for cookie encryption (required, 32+ characters recommended)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-secret-key-here-change-this-to-a-random-string

# Enable admin reset functionality (default: false)
# Set to 'true' to enable /setup/reset endpoint
# Remember to set back to 'false' after resetting
RESET_ADMIN=false
